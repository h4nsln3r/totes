# Stripe Payment Links for merch (optional).
# Create products in Stripe Dashboard → Products → Add product → then create Payment Link.
# Enable "Collect shipping address" in the Payment Link so you can ship orders.
# Paste the links here and rename this file to .env

VITE_STRIPE_LINK_TSHIRT=https://buy.stripe.com/your-tshirt-link
VITE_STRIPE_LINK_TOTEBAG=https://buy.stripe.com/your-totebag-link
